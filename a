// ─────────────────────────────────────────────────────
// 核心：対数尤度比（LLR）ベースのスコアリング
//
// 全ての指標を「設定s vs 設定1（基準）のlog尤度比」として計算。
// これにより、ぶどう・BIG・REGが同一スケールで比較可能になる。
//
// ポアソン分布 LLR:
//   LLR(obs | λs, λ1) = obs*log(λs/λ1) - (λs - λ1)
//   ※ λが近い（ぶどう等）は差が小さく → 自然に適切な重みになる
//
// 二項分布 LLR:
//   LLR(k,n | ps, p1) = k*log(ps/p1) + (n-k)*log((1-ps)/(1-p1))
// ─────────────────────────────────────────────────────
function llrPoisson(obs, lambdaS, lambdaRef){
  if(lambdaS<=0 || lambdaRef<=0) return 0;
  return obs * Math.log(lambdaS / lambdaRef) - (lambdaS - lambdaRef);
}
function llrBinomial(k, n, pS, pRef){
  if(n<=0 || pS<=0 || pRef<=0 || pS>=1 || pRef>=1) return 0;
  const ps = Math.max(1e-10, Math.min(1-1e-10, pS));
  const pr = Math.max(1e-10, Math.min(1-1e-10, pRef));
  return k*Math.log(ps/pr) + (n-k)*Math.log((1-ps)/(1-pr));
}

function analyze(){
  const games = parseInt(document.getElementById('games').value) || 0;
  const big   = parseInt(document.getElementById('big').value)   || 0;
  const reg   = parseInt(document.getElementById('reg').value)   || 0;

  // 任意入力：空欄は null
  function optVal(id){ const v=document.getElementById(id).value; return v===''?null:parseInt(v); }
  const bigS   = optVal('bigS');
  const bigC   = optVal('bigC');
  const regS   = optVal('regS');
  const regC   = optVal('regC');
  const grape  = optVal('grape');

  if(games<100){ alert('ゲーム数を入力してください（最低100G以上）'); return; }
  if(big+reg===0){ alert('BIG・REG回数を入力してください'); return; }
  if(bigS!==null && bigC!==null && bigS+bigC>big+1){ alert(`単独BIG(${bigS})+チェリーBIG(${bigC})がBIG合計(${big})を超えています`); return; }
  if(regS!==null && regC!==null && regS+regC>reg+1){ alert(`単独REG(${regS})+チェリーREG(${regC})がREG合計(${reg})を超えています`); return; }

  const m = DB[curMachine];

  // 非ボーナスゲーム数（ぶどうカウント用）
  // ボーナス消化中の平均G数を引いて通常時のみのG数を推定
  // ただし引き過ぎないよう games の30%を下限として保証
  const AVG_BIG_G=240, AVG_REG_G=96;
  const nonBG = Math.max(Math.floor(games * 0.3), games - big*AVG_BIG_G - reg*AVG_REG_G);

  // ─── スコア計算（LLR：設定1基準の対数尤度比）───
  // 重み付け（設定差の大きさに比例した重み）
  const W = {
    big:  1.0,  // BIG合算
    reg:  1.5,  // REG合算
    bigS: 1.5,  // 単独BIG
    bigC: 1.5,  // チェリーBIG
    regS: 2.5,  // 単独REG（設定差大）
    regC: 2.5,  // チェリーREG（設定差大）
    grape:3.0,  // ぶどう（最重要）
  };

  const scores = []; // 設定ごとの総合LLRスコア（設定1が基準=0）
  const fdata  = []; // 表示用データ

  // 基準（設定1）の各期待値を事前計算
  const ref = {
    big:   games / m.big[0],
    reg:   games / m.reg[0],
    bigS:  big>0 ? m.big[0]/m.bigS[0] : 0,
    bigC:  big>0 ? m.big[0]/m.bigC[0] : 0,
    regS:  reg>0 ? m.reg[0]/m.regS[0] : 0,
    regC:  reg>0 ? m.reg[0]/m.regC[0] : 0,
    grape: games / m.grape[0],
  };

  for(let s=0; s<6; s++){
    let score = 0;
    const fd  = {};

    // BIG合算
    const eBig = games / m.big[s];
    score += llrPoisson(big, eBig, ref.big) * W.big;
    fd.big = {label:'BIG合算', obs:big, exp:eBig};

    // REG合算
    const eReg = games / m.reg[s];
    score += llrPoisson(reg, eReg, ref.reg) * W.reg;
    fd.reg = {label:'REG合算', obs:reg, exp:eReg};

    // 単独BIG
    if(bigS!==null && big>0){
      const pSB = m.big[s]/m.bigS[s];
      score += llrBinomial(bigS, big, pSB, ref.bigS) * W.bigS;
      fd.bigS = {label:'単独BIG', obs:bigS, exp:big*pSB};
    }
    // チェリーBIG
    if(bigC!==null && big>0){
      const pCB = m.big[s]/m.bigC[s];
      score += llrBinomial(bigC, big, pCB, ref.bigC) * W.bigC;
      fd.bigC = {label:'チェリーBIG', obs:bigC, exp:big*pCB};
    }
    // 単独REG
    if(regS!==null && reg>0){
      const pSR = m.reg[s]/m.regS[s];
      score += llrBinomial(regS, reg, pSR, ref.regS) * W.regS;
      fd.regS = {label:'単独REG', obs:regS, exp:reg*pSR};
    }
    // チェリーREG
    if(regC!==null && reg>0){
      const pCR = m.reg[s]/m.regC[s];
      score += llrBinomial(regC, reg, pCR, ref.regC) * W.regC;
      fd.regC = {label:'チェリーREG', obs:regC, exp:reg*pCR};
    }
    // ぶどう
    if(grape!==null){
      const eGrape = games / m.grape[s];
      score += llrPoisson(grape, eGrape, ref.grape) * W.grape;
      fd.grape = {label:'ぶどう', obs:grape, exp:eGrape, obsProb:(games/grape).toFixed(2), expProb:m.grape[s].toFixed(2)};
    }

    scores.push(score);
    fdata.push(fd);
  }

  // softmax → 事後確率
  const maxS = Math.max(...scores);
  const exps = scores.map(s=>Math.exp(s-maxS));
  const sumE = exps.reduce((a,b)=>a+b,0);
  const probs = exps.map(e=>(e/sumE)*100);

  // 信頼度
  let dScore=2;
  if(bigS!==null) dScore+=1.5;
  if(bigC!==null) dScore+=1.5;
  if(regS!==null) dScore+=2;
  if(regC!==null) dScore+=2;
  if(grape!==null) dScore+=2;
  const sampleScore = Math.min(1,(big+reg)/40);
  const conf = Math.round((dScore/11.0*0.55 + sampleScore*0.45)*100);

  // ─── 表示 ───
  document.getElementById('result').style.display='block';
  document.getElementById('result').classList.add('anim');

  // Stats cards
  const bigProb  = big   ? (games/big).toFixed(1)   : '—';
  const regProb  = reg   ? (games/reg).toFixed(1)   : '—';
  const allProb  = (big+reg) ? (games/(big+reg)).toFixed(1) : '—';
  // ぶどう確率：入力されたゲーム数÷ぶどう回数でシンプルに計算（nonBGの推定誤差を排除）
  const grapeProb= (grape!==null && grape>0) ? (games/grape).toFixed(2) : null;

  let sHTML=`
    <div class="scard"><div class="slabel">BIG確率</div><div class="sval" style="font-size:14px">1/${bigProb}</div></div>
    <div class="scard"><div class="slabel">REG確率</div><div class="sval" style="font-size:14px">1/${regProb}</div></div>
    <div class="scard"><div class="slabel">合算確率</div><div class="sval" style="font-size:14px">1/${allProb}</div></div>`;
  if(grapeProb){
    const grapeRef1 = m.grape[0].toFixed(2);
    const grapeRef6 = m.grape[5].toFixed(2);
    const grapeColor = parseFloat(grapeProb) <= m.grape[5] ? '#00ff88' :
                       parseFloat(grapeProb) <= m.grape[2] ? '#ffd700' : '#7a7a9a';
    sHTML+=`<div class="scard"><div class="slabel">ぶどう確率</div><div class="sval" style="font-size:14px;color:${grapeColor}">1/${grapeProb}</div><div class="snote">${games.toLocaleString()}G中 ${grape}回<br>設定1: 1/${grapeRef1} ／ 設定6: 1/${grapeRef6}</div></div>`;
  }
  sHTML+=`<div class="scard"><div class="slabel">ゲーム数</div><div class="sval" style="font-size:13px">${games.toLocaleString()}G</div></div>`;
  document.getElementById('srow').innerHTML=sHTML;

  // 信頼度バー
  const cc=conf>=70?'#00ff88':conf>=40?'#ffd700':'#ff3d6e';
  document.getElementById('confPct').textContent=conf+'%';
  document.getElementById('confPct').style.color=cc;
  document.getElementById('confNote').textContent=
    conf>=80?'判別精度：高（十分なデータが揃っています）':
    conf>=55?'判別精度：中（ボーナス内訳・ぶどうを追加入力すると向上します）':
             '判別精度：低（ぶどう回数・ボーナス内訳の入力を推奨します）';
  setTimeout(()=>{document.getElementById('confFill').style.width=conf+'%';},80);

  // Setting bars
  const COLS=[
    'linear-gradient(90deg,#3a3a55,#5a5a77)',
    'linear-gradient(90deg,#1a3060,#3a5090)',
    'linear-gradient(90deg,#1a4a2a,#3a7a4a)',
    'linear-gradient(90deg,#504010,#907020)',
    'linear-gradient(90deg,#602010,#a04020)',
    'linear-gradient(90deg,#ff3d6e,#ff8c00)',
  ];
  let bHTML='';
  for(let s=0;s<6;s++){
    bHTML+=`<div class="brow">
      <div class="blabel">設定<b>${s+1}</b></div>
      <div class="btrack">
        <div class="bfill" id="b${s}" style="background:${COLS[s]}">
          <span class="bpct">${probs[s].toFixed(1)}%</span>
        </div>
      </div>
    </div>`;
  }
  document.getElementById('bars').innerHTML=bHTML;
  setTimeout(()=>{for(let s=0;s<6;s++) document.getElementById('b'+s).style.width=Math.max(probs[s],1.5)+'%';},80);

  // Breakdown
  const topIdx=probs.indexOf(Math.max(...probs));
  const topFD=fdata[topIdx];
  let bdHTML=`<div class="bdtitle">▸ 最有力設定（設定${topIdx+1}）との各指標比較</div><div class="bdgrid">`;
  for(const k of Object.keys(topFD)){
    const d=topFD[k];
    const diff=d.obs-d.exp;
    const pct=Math.abs(diff)/Math.max(d.exp,1)*100;
    const cls=pct<18?'ok':pct<35?'warn':'bad';
    const sign=diff>=0?'+':'';
    bdHTML+=`<div class="bditem">
      <div class="bdfactor">${d.label}</div>
      <div class="bdobs">${d.obs}回</div>
      <div class="bdexp">理論値: ${d.exp.toFixed(1)}回</div>
      <div class="bddiff ${cls}">${sign}${diff.toFixed(1)} (${sign}${pct.toFixed(0)}%)</div>
    </div>`;
  }
  bdHTML+='</div>';
  document.getElementById('bdwrap').innerHTML=bdHTML;

  // Verdict
  const topS=topIdx+1;
  const topP=probs[topIdx].toFixed(1);
  const p56=(probs[4]+probs[5]).toFixed(1);
  const p456=(probs[3]+probs[4]+probs[5]).toFixed(1);
  let vClass,vTitle,vBody;
  if(topS>=5 && probs[topIdx]>30){
    vClass='high';vTitle='🔥 高設定 濃厚！';
    vBody=`設定${topS}の可能性が最も高い（${topP}%）。<br>設定5・6の合算確率: ${p56}% ／ 設定4以上: ${p456}%<br>積極的な継続打ちを推奨します。`;
  } else if(topS>=4||parseFloat(p456)>55){
    vClass='mid';vTitle='⚡ 中〜高設定の可能性あり';
    vBody=`設定${topS}が最有力（${topP}%）。<br>設定4以上の合算確率: ${p456}%<br>データを蓄積して判断を深めましょう。`;
  } else {
    vClass='low';vTitle='📊 低設定の可能性が高め';
    vBody=`設定${topS}が最有力（${topP}%）。<br>設定4以上の合算確率: ${p456}%<br>撤退ラインを意識した立ち回りを推奨します。`;
  }
  document.getElementById('verdict').className=`verdict ${vClass}`;
  document.getElementById('verdict').innerHTML=`<div class="vt">${vTitle}</div><div class="vb">${vBody}</div>`;

  // EV grid（20スロ 46枚/1000円 → 1枚≒21.74円）
  const COIN_RATE = 1000/46; // 約21.74円/枚
  let evHTML='';
  for(let s=0;s<6;s++){
    const ev=m.ev[s];
    const evYen = Math.round(ev * COIN_RATE * 4); // 4000G想定の円換算
    const cls=ev>=0?'p':'n';
    const sg=ev>=0?'+':'';
    const yenSg=evYen>=0?'+':'';
    evHTML+=`<div class="evcard${s===topIdx?' top':''}">
      <div class="evs">設定${s+1}${s===topIdx?' ◀':''}</div>
      <div class="evn ${cls}">${yenSg}${evYen.toLocaleString()}円</div>
      <div class="evl">4,000G期待収支</div>
      <div class="evp">${probs[s].toFixed(1)}%</div>
    </div>`;
  }
  document.getElementById('evgrid').innerHTML=evHTML;

  document.getElementById('result').scrollIntoView({behavior:'smooth',block:'start'});
}

