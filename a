function calcGrapeReverse(){
  const games = parseInt(document.getElementById('gp-games').value)||0;
  const big   = parseInt(document.getElementById('gp-big').value)||0;
  const reg   = parseInt(document.getElementById('gp-reg').value)||0;
  const diff  = parseInt(document.getElementById('gp-diff').value)||0;

  if(games<100){ alert('ゲーム数を入力してください'); return; }
  if(big+reg===0){ alert('BIG・REG回数を入力してください'); return; }

  const m  = DB[gpMachine];
  const sp = GP_SPEC[gpMachine];
  if(!m || !sp){ alert('機種データが見つかりません'); return; }

  // 選択中の打ち方
  const play = (sp.plays && sp.plays.find(p=>p.id===gpPlay)) || (sp.plays && sp.plays[0]) || {cherryTake:0.667, bellTake:0, pieroTake:0};

  // 投入枚数
  const totalIn = games * 3;

  // ボーナス獲得枚数
  const bonusPay = big * (sp.bigPay||240) + reg * (sp.regPay||96);

  // リプレイ獲得枚数
  const replayPay = (games / (sp.replay||7.298)) * 3;

  // チェリー獲得枚数
  const cherryArr = sp.cherry || [35.62,35.62,35.62,35.62,35.62,35.62];
  const avgCherry = cherryArr.reduce((a,b)=>a+b,0) / 6;
  const cherryPay = (games / avgCherry) * (sp.cherryPay||2) * (play.cherryTake||0);

  // ベル獲得枚数
  const bellPay = sp.bell ? (games / sp.bell) * (sp.bellPay||14) * (play.bellTake||0) : 0;

  // ピエロ獲得枚数
  const pieroPay = sp.piero ? (games / sp.piero) * (sp.pieroPay||10) * (play.pieroTake||0) : 0;

  // ぶどう獲得枚数を逆算
  const grapeTotal = diff + totalIn - bonusPay - replayPay - cherryPay - bellPay - pieroPay;
  const grapeCount = grapeTotal / 8;
  const grapeProb  = games / grapeCount;

  if(!isFinite(grapeProb) || grapeProb <= 0){
    alert('計算できませんでした。入力値を確認してください。');
    return;
  }

  // 各設定理論値と比較
  const COLS=['#3a3a55','#3a5090','#3a7a4a','#907020','#a04020','#ff3d6e'];
  let minD=999, closest=0;
  for(let s=0;s<6;s++){
    const d=Math.abs(grapeProb - m.grape[s]);
    if(d<minD){minD=d;closest=s;}
  }

  const probColor = grapeProb <= m.grape[5] ? '#00ff88' :
                    grapeProb <= m.grape[2] ? '#ffd700'  : '#7a7a9a';

  // 結果表示（シンプル版）
  document.getElementById('gp-summary').innerHTML=`
    <div style="font-size:11px;color:#7a7a9a;margin-bottom:12px">${games.toLocaleString()}G ／ BIG${big}回 ／ REG${reg}回 ／ 差枚${diff>=0?'+':''}${diff}枚</div>
    <div style="display:flex;justify-content:center;gap:0;margin-bottom:20px;border:1px solid #252535;border-radius:12px;overflow:hidden">
      <div style="flex:1;text-align:center;padding:18px 12px;border-right:1px solid #252535">
        <div style="font-size:10px;color:#7a7a9a;letter-spacing:.12em;margin-bottom:6px">最有力設定</div>
        <div style="font-size:32px;font-weight:900;color:#ff3d6e">設定${closest+1}</div>
      </div>
      <div style="flex:1;text-align:center;padding:18px 12px;border-right:1px solid #252535">
        <div style="font-size:10px;color:#7a7a9a;letter-spacing:.12em;margin-bottom:6px">理論値</div>
        <div style="font-size:24px;font-weight:700;color:#dde0f0">1/${m.grape[closest].toFixed(2)}</div>
      </div>
      <div style="flex:1;text-align:center;padding:18px 12px">
        <div style="font-size:10px;color:#7a7a9a;letter-spacing:.12em;margin-bottom:6px">逆算値</div>
        <div style="font-size:24px;font-weight:700;color:${probColor}">1/${grapeProb.toFixed(2)}</div>
      </div>
    </div>`;

  // ぶどう逆算からベイズ確率を計算
  // 正規分布近似：標準偏差 = sqrt(p*(1-p)/n) / p^2 で1/確率の標準偏差を近似
  // 簡易版：各設定の理論確率との差をガウス尤度で評価
  const gpProbs = [];
  for(let s=0;s<6;s++){
    const theory = 1/m.grape[s];
    const obs    = 1/grapeProb;
    const sigma  = Math.sqrt(theory*(1-theory)/games);
    const z      = (obs - theory) / sigma;
    gpProbs.push(Math.exp(-0.5*z*z));
  }
  const gpSum = gpProbs.reduce((a,b)=>a+b,0);
  const gpPct = gpProbs.map(p=>(p/gpSum*100));

  // 設定別確率バー
  const COLS2=[
    'linear-gradient(90deg,#3a3a55,#5a5a77)',
    'linear-gradient(90deg,#1a3060,#3a5090)',
    'linear-gradient(90deg,#1a4a2a,#3a7a4a)',
    'linear-gradient(90deg,#504010,#907020)',
    'linear-gradient(90deg,#602010,#a04020)',
    'linear-gradient(90deg,#ff3d6e,#ff8c00)',
  ];
  let html='';
  for(let s=0;s<6;s++){
    const theory = m.grape[s];
    const isTop  = s===closest;
    html+=`<div class="brow" style="${isTop?'opacity:1':'opacity:.85'}">
      <div class="blabel">設定<b>${s+1}</b></div>
      <div class="btrack">
        <div class="bfill" id="gpb${s}" style="background:${COLS2[s]};width:0%">
          <span class="bpct">${gpPct[s].toFixed(1)}%</span>
        </div>
      </div>
      <div style="font-size:10px;color:#7a7a9a;min-width:52px;text-align:right">1/${theory.toFixed(2)}</div>
    </div>`;
  }
  document.getElementById('gp-rows').innerHTML=html;
  setTimeout(()=>{for(let s=0;s<6;s++) document.getElementById('gpb'+s).style.width=Math.max(gpPct[s],1.5)+'%';},80);

  document.getElementById('gp-result').style.display='block';
  document.getElementById('gp-result').classList.add('anim');
  document.getElementById('gp-result').scrollIntoView({behavior:'smooth',block:'start'});
}

function resetGrapeReverse(){
  ['gp-games','gp-big','gp-reg','gp-diff'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('gp-result').style.display='none';
}


