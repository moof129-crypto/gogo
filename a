function getKey(){
  const el=document.getElementById('ai-apikey');
  return el&&el.value.trim()?el.value.trim():"AIzaSyCoed6Y9h6qNuv5mGKUvY5yXFjg-JHleHk";
}

async function callGemini(userMsg){
  const key=getKey();
  if(!key) throw new Error('APIキーを入力してください');
  const contents=[];
  for(let i=0;i<aiHistory.length;i++){
    contents.push({role:aiHistory[i].role==='assistant'?'model':'user',parts:[{text:aiHistory[i].content}]});
  }
  contents.push({role:'user',parts:[{text:userMsg}]});
  const res=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=${key}`,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({system_instruction:{parts:[{text:buildSystemPrompt()}]},contents,generationConfig:{maxOutputTokens:1000,temperature:0.7}})
  });
  const data=await res.json();
  if(data.error) throw new Error(data.error.message);
  return data.candidates?.[0]?.content?.parts?.[0]?.text||'エラー';
}

async function askAI(){
  const key = getKey();
  if(!key){
    document.getElementById('ai-apikey-wrap').style.display='block';
    document.getElementById('ai-apikey').focus();
    return;
  }

  const btn  = document.getElementById('ai-btn');
  const chat = document.getElementById('ai-chat');
  const msgs = document.getElementById('ai-messages');

  btn.textContent = '⏳ 分析中...';
  btn.disabled = true;
  chat.style.display = 'block';
  msgs.textContent = '分析中...';
  aiHistory = [];

  const userMsg = `以下の台データについてスロプロとしてアドバイスをください。\n\n${buildDataSummary()}\nこの台は打ち続けるべきか、設定の可能性と根拠、立ち回りのポイントを教えてください。`;

  try {
    const reply = await callGemini(userMsg);
    aiHistory.push({role:'user', content: userMsg});
    aiHistory.push({role:'assistant', content: reply});
    msgs.textContent = reply;
    document.getElementById('ai-apikey-wrap').style.display='none';
  } catch(e) {
    msgs.textContent = 'エラー: ' + e.message;
    document.getElementById('ai-apikey-wrap').style.display='block';
  }

  btn.textContent = '🤖 この台についてAIに相談する';
  btn.disabled = false;
}

async function followupAI(){
  const input = document.getElementById('ai-input');
  const msgs  = document.getElementById('ai-messages');
  const q = input.value.trim();
  if(!q) return;
  input.value = '';
  msgs.textContent += '\n\n━━━━━━━━━━\n👤 ' + q + '\n\n⏳ 回答中...';
  try {
    const reply = await callGemini(q);
    aiHistory.push({role:'user', content: q});
    aiHistory.push({role:'assistant', content: reply});
    msgs.textContent = msgs.textContent.replace('⏳ 回答中...', reply);
  } catch(e) {
    msgs.textContent += '\nエラー: ' + e.message;
  }
}

