  const rC = document.getElementById('regC').value;
  const gr = document.getElementById('grape').value;
  let s = `【機種】${m.name}\n`;
  s += `【データ】${g}G / BIG${b}回(1/${b?Math.round(g/b):'—'}) / REG${r}回(1/${r?Math.round(g/r):'—'})\n`;
  if(bS||bC) s += `【ボーナス内訳】単独BIG:${bS||'—'} チェリーBIG:${bC||'—'}\n`;
  if(rS||rC) s += `              単独REG:${rS||'—'} チェリーREG:${rC||'—'}\n`;
  if(gr)     s += `【ぶどう】${gr}回 (1/${Math.round(g/parseInt(gr))})\n`;
  const bars = document.querySelectorAll('.bpct');
  if(bars.length===6){
    const probs = Array.from(bars).map(el=>parseFloat(el.textContent));
