// ぶどう逆算
function calcGrape(){
  const g  = parseInt(document.getElementById('gp-games').value)||0;
  const gn = parseInt(document.getElementById('gp-grape').value)||0;
  if(g<100||gn<=0){ alert('ゲーム数とぶどう回数を入力してください'); return; }

  const prob = g / gn;
  const m = DB[curMachine];

  // 設定ごとの理論値と乖離
  let html='';
  const COLS=['#3a3a55','#3a5090','#3a7a4a','#907020','#a04020','#ff3d6e'];
  for(let s=0;s<6;s++){
    const theory = m.grape[s];
    const diff   = prob - theory;
    const diffPct= (diff/theory*100);
    const cls    = Math.abs(diffPct)<3 ? 'gp-ok' : diff<0 ? 'gp-hi' : 'gp-lo';
    const sg     = diff>=0?'+':'';
    // 観測値が設定s理論値以下なら高設定方向
    const bar = Math.min(100, Math.max(2, 100 - Math.abs(diffPct)*3));
    html+=`<div class="gp-row">
      <div class="gp-slabel">設定${s+1}</div>
      <div class="gp-theory">理論値 1/${theory.toFixed(2)}</div>
      <div class="gp-track"><div class="gp-fill" style="width:${bar}%;background:${COLS[s]}"></div></div>
      <div class="gp-diff ${cls}">${sg}${diff.toFixed(3)}（${sg}${diffPct.toFixed(1)}%）</div>
    </div>`;
  }

  // 最も近い設定
  let minD=999, closest=0;
  for(let s=0;s<6;s++){
    const d=Math.abs(prob - m.grape[s]);
    if(d<minD){minD=d;closest=s;}
  }

  const probColor = prob <= m.grape[5] ? '#00ff88' :
                    prob <= m.grape[2] ? '#ffd700'  : '#7a7a9a';

  document.getElementById('gp-result').style.display='block';
  document.getElementById('gp-result').classList.add('anim');
  document.getElementById('gp-prob').innerHTML=
    `<span style="color:${probColor};font-size:28px;font-weight:700">1/${prob.toFixed(2)}</span>
     <span style="font-size:12px;color:#7a7a9a;margin-left:8px">${g.toLocaleString()}G中 ${gn}回</span>`;
  document.getElementById('gp-closest').textContent = `最も近い理論値：設定${closest+1}（1/${m.grape[closest].toFixed(2)}）`;
  document.getElementById('gp-rows').innerHTML=html;
  setTimeout(()=>document.querySelectorAll('.gp-fill').forEach(el=>{
    const w=el.style.width; el.style.width='0'; setTimeout(()=>el.style.width=w,50);
  }),50);
}

