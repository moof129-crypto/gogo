function buildDataSummary(){
  const m  = DB[curMachine];
  const g  = parseInt(document.getElementById('games').value)||0;
  const b  = parseInt(document.getElementById('big').value)||0;
  const r  = parseInt(document.getElementById('reg').value)||0;
